{
  "name": "book-producer",
  "version": "0.1.0",
  "description": "Multi-tool, stage-based book creation framework installable from npm and GitHub Packages.",
  "keywords": [
    "book",
    "writing",
    "ai",
    "claude",
    "agents",
    "framework",
    "npm",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrudinal/book-producer.git"
  },
  "bugs": {
    "url": "https://github.com/mrudinal/book-producer/issues"
  },
  "homepage": "https://github.com/mrudinal/book-producer#readme",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "book-producer": "bin/book-framework.js"
  },
  "main": "dist/cli.js",
  "files": [
    "bin",
    "dist",
    "assets",
    "README.md",
    "CHANGELOG.md",
    "VERSIONS.md",
    "TROUBLESHOOTING.md",
    "UPGRADING.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node ./scripts/clean-dist.mjs && tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "prepare:publish:npm": "node ./scripts/prepare-registry-package.mjs --registry npm --out .release/npm",
    "prepare:publish:github": "node ./scripts/prepare-registry-package.mjs --registry github --out .release/github",
    "pack:npm": "npm run build && npm run prepare:publish:npm && npm pack ./.release/npm",
    "pack:github": "npm run build && npm run prepare:publish:github && npm pack ./.release/github",
    "prepublishOnly": "npm run build && npm test && npm run lint"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "fs-extra": "^11.2.0",
    "inquirer": "^9.2.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.12.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "typescript": "5.5.4",
    "vitest": "^4.1.2"
  },
  "type": "module"
}
